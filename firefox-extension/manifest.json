{
  "manifest_version": 3,
  "name": "Button Fireworks",
  "version": "2.0",
  "description": "Displays fireworks when buttons are clicked on web pages",
  "icons": {
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "options.html",
    "default_icon": {
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["fireworks.js"],
      "css": ["fireworks.css"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "button-fireworks@example.com",
      "strict_min_version": "115.0"
    }
  },
  "host_permissions": ["<all_urls>"],
  "permissions": ["storage"]
}